<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:layout_marginTop="15dp"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/activity_container_border">

    <TextView
        android:id="@+id/tvDataAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Facebook"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvDataUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="johndewey.altura1"
        android:textSize="18sp"
        android:layout_marginTop="5dp"/>
    <TextView
        android:id="@+id/tvDataEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="johndewey02003@gmail.com"/>

    <TextView
        android:id="@+id/tvDocId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

</androidx.appcompat.widget.LinearLayoutCompat>